# PostgreSQL connection string for SetareganPlus.
# Replace placeholders before running migrations on the VPS.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/setareganplus?schema=public"

# Persistent media root (outside the git deploy tree). Production example:
# STAROS_MEDIA_ROOT=/var/www/staros-media
STAROS_MEDIA_ROOT=

# Public URL prefix served by Nginx alias (no trailing slash required).
# Example: /media → files at /media/forms/<file>
STAROS_MEDIA_PUBLIC_BASE=/media

# Optional AI assistance (advisory only — booking works without AI).
# Never commit real API keys.
STAROS_AI_ENABLED=false
STAROS_AI_PROVIDER=none
# STAROS_AI_ENDPOINT=
# STAROS_AI_API_KEY=
# STAROS_AI_TIMEOUT_MS=4000
