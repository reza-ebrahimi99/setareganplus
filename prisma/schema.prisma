  FORM_TOTAL
  VERSION
  BRANCH
  VERSION_BRANCH
}

model Organization {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  legalName String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  branches                 Branch[]
  leads                    Lead[]
  memberships              OrganizationMembership[]
  auditLogs                AuditLog[]
  forms                    Form[]
  formVersions             FormVersion[]
  formSteps                FormStep[]
  formFields               FormField[]
  formSubmissions          FormSubmission[]
  formAnswers              FormAnswer[]
  formTemplates            FormTemplate[]
  formTemplateFields       FormTemplateField[]
  tags                     Tag[]
  formTags                 FormTag[]
  formSubmissionTags       FormSubmissionTag[]
  automationRules          AutomationRule[]
  domainEvents             DomainEventOutbox[]
  formAnalyticsEvents      FormAnalyticsEvent[]
  formAnalyticsDaily       FormAnalyticsDaily[]
  mediaAssets              MediaAsset[]
  galleryAlbums            GalleryAlbum[]
  mediaPlacements          MediaPlacement[]
  websiteMarketingCards    WebsiteMarketingCard[]
  websitePages             WebsitePage[]
  websitePageSections      WebsitePageSection[]
  websitePageSectionMedia  WebsitePageSectionMedia[]
  bookingServices          BookingService[]
  bookingAdvisors          BookingAdvisor[]
  bookingSlots             BookingSlot[]
  bookingReservations      BookingReservation[]
  sitePlacements           SitePlacement[]
  smsTemplates             SmsTemplate[]
  smsMessages              SmsMessage[]
  otpChallenges            OtpChallenge[]
  crmPipelines             CrmPipeline[]
  crmPipelineStages        CrmPipelineStage[]
  crmTasks                 CrmTask[]
  crmActivities            CrmActivity[]
  crmCallLogs              CrmCallLog[]
  crmLeadImportReports     CrmLeadImportReport[]
  automationExecutions     AutomationExecution[]
  teamDepartments          TeamDepartment[]
  teamMembers              TeamMember[]
  studentGrades            StudentGrade[]
  studentMajors            StudentMajor[]
  students                 Student[]
  achievementCategories    AchievementCategory[]
  achievements             Achievement[]
  assessmentProviders      AssessmentProvider[]
  subjects                 Subject[]
  assessments              Assessment[]
  assessmentResults        AssessmentResult[]
  studentGuardians           StudentGuardian[]
  studentGuardianRelations   StudentGuardianRelation[]
  portalAccountLinks         PortalAccountLink[]
  registrations              Registration[]
  registrationNumberCounters RegistrationNumberCounter[]
  paymentIntents             PaymentIntent[]
  paymentSessions            PaymentSession[]
  paymentEventLogs           PaymentEventLog[]

  @@map("organizations")
}

model Branch {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  slug           String
  city           String?
  province       String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  // Restrict: hard-deleting an organization is blocked while branches exist.
  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  leads                Lead[]
  activities           LeadActivity[]
  consents             ConsentRecord[]
  branchMemberships    BranchMembership[]
  auditLogs            AuditLog[]
  forms                Form[]
  formSubmissions      FormSubmission[]
  domainEvents         DomainEventOutbox[]
  formAnalyticsEvents  FormAnalyticsEvent[]
  bookingServices      BookingService[]
  bookingAdvisors      BookingAdvisor[]
  bookingSlots         BookingSlot[]
  crmLeadImportReports CrmLeadImportReport[]
  registrations        Registration[]

  @@unique([organizationId, slug])
  @@unique([organizationId, id])
  @@index([organizationId, isActive])
  @@index([organizationId, deletedAt])
  @@map("branches")
}

model User {
  id               String     @id @default(cuid())
  email            String?    @unique
  mobile           String?
  normalizedMobile String?    @unique
  passwordHash     String?
  firstName        String
  lastName         String
  status           UserStatus @default(INVITED)
  isPlatformAdmin  Boolean    @default(false)
  emailVerifiedAt  DateTime?
  mobileVerifiedAt DateTime?
  lastLoginAt      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  deletedAt        DateTime?

  memberships          OrganizationMembership[]
  auditLogs            AuditLog[]               @relation("AuditLogActor")
  adminSessions        AdminSession[]
  mediaAssets          MediaAsset[]             @relation("MediaAssetCreator")
  bookingAdvisors      BookingAdvisor[]
  bookingCheckIns      BookingCheckIn[]
  ownedLeads           Lead[]                   @relation("LeadOwner")
  assignedCrmTasks     CrmTask[]                @relation("CrmTaskAssignee")
  createdCrmTasks      CrmTask[]                @relation("CrmTaskCreator")
  crmActivities        CrmActivity[]            @relation("CrmActivityActor")
  crmLeadImportReports CrmLeadImportReport[]    @relation("CrmLeadImportActor")
  portalAccountLinks   PortalAccountLink[]

  @@index([status])
  @@index([deletedAt])
  @@index([isPlatformAdmin])
  @@map("users")
}

// Server-side admin sessions (v0.4.1a). Cookie stores opaque token; DB stores tokenHash only.
model AdminSession {
  id                       String    @id @default(cuid())
  userId                   String
  organizationMembershipId String?
  tokenHash                String    @unique
  expiresAt                DateTime
  revokedAt                DateTime?
  ipAddress                String?
  userAgent                String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  user       User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  membership OrganizationMembership? @relation(fields: [organizationMembershipId], references: [id], onDelete: Restrict)

  @@index([userId, expiresAt])
  @@index([organizationMembershipId, expiresAt])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("admin_sessions")
}

model OrganizationMembership {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  role           SystemRole
  status         MembershipStatus @default(INVITED)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?

  // Restrict: preserve membership history; soft-delete via deletedAt instead of hard delete.
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user              User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  branchMemberships BranchMembership[]
  adminSessions     AdminSession[]
  crmCallLogs       CrmCallLog[]

  // One membership row per user per organization. Reactivation after soft-delete must
  // UPDATE this row (clear deletedAt, adjust status) — not INSERT a duplicate.
  @@unique([organizationId, userId])
  @@unique([organizationId, id])
  @@index([organizationId, status])
  @@index([organizationId, role])
  @@index([organizationId, deletedAt])
  @@index([userId, status])
  @@map("organization_memberships")
}

model BranchMembership {
  id                       String    @id @default(cuid())
  organizationMembershipId String
  organizationId           String
  branchId                 String
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  deletedAt                DateTime?

  // Restrict: branch scope rows are historical access records, not cascade-deleted.
  // Composite FK: branchId must belong to the same organizationId.
  organizationMembership OrganizationMembership @relation(fields: [organizationId, organizationMembershipId], references: [organizationId, id], onDelete: Restrict)
  branch                 Branch                 @relation(fields: [organizationId, branchId], references: [organizationId, id], onDelete: Restrict)

  // One active scope row per branch per organization membership.
  @@unique([organizationMembershipId, branchId])
  @@index([organizationId, branchId])
  @@index([organizationId, organizationMembershipId])
  @@index([organizationId, deletedAt])
  @@map("branch_memberships")
}

model AuditLog {
  id             String      @id @default(cuid())
  organizationId String?
  branchId       String?
  actorUserId    String?
  action         AuditAction
  entityType     String
  entityId       String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime    @default(now())

  // Restrict: audit evidence must survive entity lifecycle; block hard deletes instead.
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch       Branch?       @relation(fields: [organizationId, branchId], references: [organizationId, id], onDelete: Restrict)
  // SetNull: retain audit rows if a user account is hard-deleted; actor becomes anonymous.
  actor        User?         @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([branchId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model Lead {
  id                         String          @id @default(cuid())
  organizationId             String
  branchId                   String
  /// Legacy compatibility status. Pipeline stage (stageId) is the operational source of truth
  /// when set; status is kept in sync via stageType → LeadStatus mapping.
  status                     LeadStatus      @default(NEW)
  firstName                  String
  lastName                   String
  fatherName                 String?
  mobile                     String
  mobileRaw                  String
  /// Normalized Iranian mobile for dedupe (09xxxxxxxxx).
  normalizedMobile           String?
  school                     String?
  gradeLevel                 String?
  studyField                 String?
  city                       String?
  province                   String?
  gender                     Gender?
  birthDate                  DateTime?       @db.Date
  nationalCode               String?
  serviceInterest            ServiceInterest @default(UNDECIDED)
  description                String?
  source                     String          @default("WEB_PRE_REGISTRATION")
  sourceType                 LeadSourceType  @default(OTHER)
  sourceFormSubmissionId     String?
  sourceBookingReservationId String?
  pipelineId                 String?
  stageId                    String?
  /// Canonical Lead Owner: the sales advisor responsible for this lead.
  /// Reused by assignment, queueing, reminders, automation, and reporting.
  ownerUserId                String?
  score                      Int             @default(0)
  scoreBand                  LeadScoreBand   @default(COLD)
  scoreBreakdown             Json?
  nextFollowUpAt             DateTime?
  lastContactAt              DateTime?
  convertedAt                DateTime?
  lostAt                     DateTime?
  lostReason                 String?
  metadata                   Json?
  isDuplicate                Boolean         @default(false)
  duplicateOfId              String?
  createdAt                  DateTime        @default(now())
  updatedAt                  DateTime        @updatedAt
  deletedAt                  DateTime?

  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch              Branch               @relation(fields: [organizationId, branchId], references: [organizationId, id], onDelete: Restrict)
  duplicateOf         Lead?                @relation("LeadDuplicates", fields: [duplicateOfId], references: [id], onDelete: SetNull)
  duplicates          Lead[]               @relation("LeadDuplicates")
  pipeline            CrmPipeline?         @relation(fields: [organizationId, pipelineId], references: [organizationId, id], onDelete: Restrict)
  stage               CrmPipelineStage?    @relation(fields: [organizationId, stageId], references: [organizationId, id], onDelete: Restrict)
  owner               User?                @relation("LeadOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  activities          LeadActivity[]
  consents            ConsentRecord[]
  formSubmissions     FormSubmission[]
  crmTasks            CrmTask[]
  crmActivities       CrmActivity[]
  crmCallLogs         CrmCallLog[]
  bookingReservations BookingReservation[]
  registrations       Registration[]

  @@unique([organizationId, branchId, id])
  @@unique([organizationId, id])
  @@index([organizationId, branchId])
  @@index([organizationId, status])
  @@index([organizationId, mobile])
  @@index([organizationId, normalizedMobile])
  @@index([organizationId, pipelineId, stageId])
  @@index([organizationId, ownerUserId])
  @@index([organizationId, branchId, ownerUserId, updatedAt])
  @@index([organizationId, scoreBand])
  @@index([organizationId, nextFollowUpAt])
  @@index([organizationId, sourceFormSubmissionId])
  @@index([organizationId, sourceBookingReservationId])
  @@index([organizationId, createdAt])
  @@index([organizationId, deletedAt])
  @@map("leads")
}

/// CRM-specific import outcome summary. Source files remain ephemeral; only the
/// existing importer result is retained for dashboard reporting and CSV download.
model CrmLeadImportReport {
  id                String   @id @default(cuid())
  organizationId    String
  branchId          String
  importedByUserId  String?
  sourceFileName    String
  totalRows         Int
  createdCount      Int
  updatedCount      Int
  skippedCount      Int
  invalidCount      Int
  failedCount       Int
  duplicateCount    Int
  ownerDistribution Json     @default("[]")
  resultCsv         String   @db.Text
  createdAt         DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch       Branch       @relation(fields: [organizationId, branchId], references: [organizationId, id], onDelete: Restrict)
  importedBy   User?        @relation("CrmLeadImportActor", fields: [importedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, branchId, createdAt])
  @@index([organizationId, importedByUserId, createdAt])
  @@map("crm_lead_import_reports")
}

model LeadActivity {
  id             String           @id @default(cuid())
  organizationId String
  branchId       String
  leadId         String
  type           LeadActivityType
  content        String
  previousStatus LeadStatus?
  newStatus      LeadStatus?
  createdAt      DateTime         @default(now())

  // Cascade: activity rows are dependent history; only applies on hard delete.
  // Soft-deleted leads keep activities via deletedAt on Lead.
  lead   Lead   @relation(fields: [organizationId, branchId, leadId], references: [organizationId, branchId, id], onDelete: Cascade)
  branch Branch @relation(fields: [organizationId, branchId], references: [organizationId, id], onDelete: Restrict)

  @@index([organizationId, branchId])
  @@index([organizationId, leadId, createdAt])
  @@map("lead_activities")
}

model ConsentRecord {
  id             String      @id @default(cuid())
  organizationId String
  branchId       String
  leadId         String
  consentType    ConsentType
  consentText    String
  consentVersion String
  ipAddress      String?
  userAgent      String?
  grantedAt      DateTime    @default(now())

  // Cascade: consent evidence is tied to a lead record (hard delete only).
  lead   Lead   @relation(fields: [organizationId, branchId, leadId], references: [organizationId, branchId, id], onDelete: Cascade)
  branch Branch @relation(fields: [organizationId, branchId], references: [organizationId, id], onDelete: Restrict)

  @@index([organizationId, branchId])
  @@index([organizationId, leadId])
  @@map("consent_records")
}

// ─── Form template library ───────────────────────────────────────────────────
// System-owned templates have organizationId = null and scope = SYSTEM.
// Instantiating a template creates an independent Form + draft FormVersion.

model FormTemplate {
  id              String               @id @default(cuid())
  scope           FormTemplateScope
  organizationId  String?
  category        FormTemplateCategory
  name            String
  description     String?
  purpose         FormPurpose
  defaultSettings Json                 @default("{}")
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deletedAt       DateTime?

  organization Organization?       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  fields       FormTemplateField[]
  versions     FormVersion[]

  @@index([scope, category, isActive])
  @@index([organizationId, category])
  @@index([organizationId, deletedAt])
  @@map("form_templates")
}

model FormTemplateField {
  id                   String            @id @default(cuid())
  organizationId       String?
  templateId           String
  fieldKey             String
  sortOrder            Int
  type                 FormFieldType
  semantic             FormFieldSemantic @default(NONE)
  label                String
  helpText             String?
  placeholder          String?
  required             Boolean           @default(false)
  config               Json              @default("{}")
  visibilityConditions Json?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  template     FormTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, fieldKey])
  @@unique([templateId, sortOrder])
  @@index([templateId, sortOrder])
  @@map("form_template_fields")
}

// ─── Persistent media assets (outside git / deploy tree) ─────────────────────

enum MediaAssetStatus {
  ACTIVE
  INACTIVE
}

model MediaAsset {
  id              String           @id @default(cuid())
  organizationId  String
  storageKey      String           @unique
  originalName    String
  mimeType        String
  byteSize        Int
  checksum        String
  width           Int?
  height          Int?
  altText         String?
  /// Editorial title for library browsing and public captions.
  title           String?
  /// Editorial description (separate from technical metadata JSON).
  description     String?
  /// Optional free-text category label (normalized whitespace, max length enforced in app).
  category        String?
  status          MediaAssetStatus @default(ACTIVE)
  /// Optional structured technical metadata (e.g. team portrait variant keys).
  metadata        Json?
  createdByUserId String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?

  organization            Organization              @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  createdBy               User?                     @relation("MediaAssetCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  formPosters             FormVersion[]             @relation("FormVersionPoster")
  teamPortraits           TeamMember[]              @relation("TeamMemberPortrait")
  studentPortraits        Student[]                 @relation("StudentPortrait")
  achievementCertificates Achievement[]             @relation("AchievementCertificate")
  achievementCovers       Achievement[]             @relation("AchievementCover")
  galleryAlbumCovers      GalleryAlbum[]            @relation("GalleryAlbumCover")
  galleryAlbumItems       GalleryAlbumItem[]
  mediaPlacements         MediaPlacement[]
  websiteMarketingCards   WebsiteMarketingCard[]    @relation("WebsiteMarketingCardImage")
  websitePageSectionMedia WebsitePageSectionMedia[] @relation("WebsitePageSectionMediaAsset")
  websitePageSeoImages    WebsitePage[]             @relation("WebsitePageSeoImage")

  @@index([organizationId, deletedAt])
  @@index([organizationId, createdAt])
  @@index([organizationId, status, deletedAt])
  @@index([organizationId, category])
  @@index([createdByUserId])
  @@map("media_assets")
}

// ─── Media Library / Gallery CMS ─────────────────────────────────────────────

model GalleryAlbum {
  id             String    @id @default(cuid())
  organizationId String
  title          String
  slug           String
  description    String?
  coverMediaId   String?
  isActive       Boolean   @default(true)
  sortOrder      Int       @default(0)
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  coverMedia   MediaAsset?        @relation("GalleryAlbumCover", fields: [coverMediaId], references: [id], onDelete: SetNull)
  items        GalleryAlbumItem[]
  placements   MediaPlacement[]

  @@unique([organizationId, slug])
  @@index([organizationId, deletedAt, isActive, sortOrder])
  @@index([organizationId, publishedAt])
  @@index([coverMediaId])
  @@map("gallery_albums")
}

model GalleryAlbumItem {
  id        String   @id @default(cuid())
  albumId   String
  mediaId   String
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  album GalleryAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)
  media MediaAsset   @relation(fields: [mediaId], references: [id], onDelete: Restrict)

  @@unique([albumId, mediaId])
  @@index([albumId, sortOrder])
  @@index([mediaId])
  @@map("gallery_album_items")
}

model MediaPlacement {
  id                  String    @id @default(cuid())
  organizationId      String
  placementKey        String
  mediaId             String?
  albumId             String?
  titleOverride       String?
  descriptionOverride String?
  sortOrder           Int       @default(0)
  isActive            Boolean   @default(true)
  /// Optional schedule window. DB enforces media_placements_schedule_check:
  /// both NULL, only startAt, only endAt, or both with endAt > startAt.
  startAt             DateTime?
  endAt               DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  media        MediaAsset?   @relation(fields: [mediaId], references: [id], onDelete: Restrict)
  album        GalleryAlbum? @relation(fields: [albumId], references: [id], onDelete: Restrict)

  @@index([organizationId, placementKey, deletedAt, isActive, sortOrder])
  @@index([mediaId])
  @@index([albumId])
  @@map("media_placements")
}

// ─── Website marketing cards (homepage Qalamchi / future sections) ───────────

model WebsiteMarketingCard {
  id             String    @id @default(cuid())
  organizationId String
  /// Allowlisted section key, e.g. HOMEPAGE_QALAMCHI
  sectionKey     String
  title          String
  description    String    @default("")
  /// Optional badge under the image; empty → public UI default.
  badge          String?
  imageMediaId   String?
  /// Optional alt override; public loader falls back to MediaAsset.altText then title.
  imageAlt       String?
  sortOrder      Int       @default(0)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  imageMedia   MediaAsset?  @relation("WebsiteMarketingCardImage", fields: [imageMediaId], references: [id], onDelete: SetNull)

  @@index([organizationId, sectionKey, deletedAt, isActive, sortOrder])
  @@index([imageMediaId])
  @@map("website_marketing_cards")
}

// ─── Visual Page Builder ─────────────────────────────────────────────────────

enum WebsitePageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum WebsiteSectionStatus {
  DRAFT
  PUBLISHED
  DISABLED
}

model WebsitePage {
  id              String            @id @default(cuid())
  organizationId  String
  slug            String
  title           String
  seoTitle        String?
  seoDescription  String?
  /// Optional dedicated Open Graph / SEO image (Phase 2.1+; used in Phase 2.5).
  seoImageMediaId String?
  /// Audit-only template key from create factories (e.g. blank, about).
  templateKey     String?
  status          WebsitePageStatus @default(DRAFT)
  publishedAt     DateTime?
  archivedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?

  organization  Organization         @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  seoImageMedia MediaAsset?          @relation("WebsitePageSeoImage", fields: [seoImageMediaId], references: [id], onDelete: SetNull)
  sections      WebsitePageSection[]

  /// Live-slug uniqueness is enforced by partial unique index in SQL:
  /// website_pages_organizationId_slug_live_key (WHERE deletedAt IS NULL)
  @@index([organizationId, status, deletedAt])
  @@index([organizationId, status, archivedAt, deletedAt])
  @@index([seoImageMediaId])
  @@map("website_pages")
}

model WebsitePageSection {
  id             String               @id @default(cuid())
  organizationId String
  pageId         String
  /// Allowlisted section type (HERO, IMAGE, RICH_TEXT, CTA, SPACER, …)
  type           String
  status         WebsiteSectionStatus @default(DRAFT)
  sortOrder      Int                  @default(0)
  /// Typed JSON validated by Section Registry for `type`
  config         Json                 @default("{}")
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  deletedAt      DateTime?

  organization Organization              @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  page         WebsitePage               @relation(fields: [pageId], references: [id], onDelete: Cascade)
  mediaLinks   WebsitePageSectionMedia[]

  @@index([organizationId, pageId, deletedAt, status, sortOrder])
  @@index([pageId, deletedAt, sortOrder])
  @@map("website_page_sections")
}

model WebsitePageSectionMedia {
  id             String @id @default(cuid())
  organizationId String
  sectionId      String
  mediaId        String
  /// Semantic role within section config (e.g. primary, mobile, background)
  role           String
  sortOrder      Int    @default(0)

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  section      WebsitePageSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  media        MediaAsset         @relation("WebsitePageSectionMediaAsset", fields: [mediaId], references: [id], onDelete: Restrict)

  @@unique([sectionId, role, sortOrder])
  @@index([mediaId])
  @@index([organizationId, mediaId])
  @@index([sectionId, sortOrder])
  @@map("website_page_section_media")
}

// ─── Form parent identity (stable slug) ──────────────────────────────────────

model Form {
  id                 String      @id @default(cuid())
  organizationId     String
  branchId           String?
  slug               String
  purpose            FormPurpose
  mode               FormMode    @default(STANDARD)
  isAdmissionForm    Boolean     @default(false)
  publishedVersionId String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  deletedAt          DateTime?

  organization     Organization         @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch           Branch?              @relation(fields: [organizationId, branchId], references: [organizationId, id], onDelete: Restrict)
  versions         FormVersion[]        @relation("FormVersions")
  publishedVersion FormVersion?         @relation("FormPublishedVersion", fields: [organizationId, publishedVersionId], references: [organizationId, id], onDelete: Restrict)
  submissions      FormSubmission[]
  tags             FormTag[]
  automationRules  AutomationRule[]
  analyticsEvents  FormAnalyticsEvent[]
  analyticsDaily   FormAnalyticsDaily[]
  bookingServices  BookingService[]
  sitePlacements   SitePlacement[]

  @@unique([organizationId, slug])
  @@unique([organizationId, id])
  @@index([organizationId, purpose])
  @@index([organizationId, mode])
  @@index([organizationId, isAdmissionForm])
  @@index([organizationId, deletedAt])
  @@map("forms")
}

// ─── Versioned form definition ───────────────────────────────────────────────
//
// Status rules:
//   DRAFT      — editable; not linked from Form.publishedVersionId; no submissions.
//   PUBLISHED  — frozen; accepts submissions; only status allowed on publishedVersionId.
//   PAUSED     — frozen; rejects submissions; must not be on publishedVersionId.
//   SUPERSEDED — frozen; replaced by a newer publish; no submissions.
//   ARCHIVED   — frozen; retired; no submissions.
//
// Partial unique index (future raw SQL — Prisma cannot express):
//   CREATE UNIQUE INDEX form_versions_one_published_per_form
//     ON form_versions (organization_id, form_id) WHERE status = 'PUBLISHED';
//   Enforces at most one PUBLISHED version per form at the database level.

model FormVersion {
  id                   String            @id @default(cuid())
  organizationId       String
  formId               String
  versionNumber        Int
  status               FormVersionStatus @default(DRAFT)
  title                String
  description          String?
  opensAt              DateTime?
  registrationDeadline DateTime?
  capacity             Int?
  confirmationMessage  String
  duplicatePolicy      DuplicatePolicy   @default(FLAG_AND_ACCEPT)
  createLeadOnSubmit   Boolean           @default(false)
  leadSource           String?
  showBranchPicker     Boolean           @default(false)
  settings             Json              @default("{}")
  sourceTemplateId     String?
  posterMediaId        String?
  publishedAt          DateTime?
  pausedAt             DateTime?
  archivedAt           DateTime?
  createdByUserId      String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  organization     Organization         @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  form             Form                 @relation("FormVersions", fields: [organizationId, formId], references: [organizationId, id], onDelete: Restrict)
  sourceTemplate   FormTemplate?        @relation(fields: [sourceTemplateId], references: [id], onDelete: Restrict)
  posterMedia      MediaAsset?          @relation("FormVersionPoster", fields: [posterMediaId], references: [id], onDelete: SetNull)
  steps            FormStep[]
  fields           FormField[]
  submissions      FormSubmission[]
  formsAsPublished Form[]               @relation("FormPublishedVersion")
  analyticsEvents  FormAnalyticsEvent[]

  @@unique([organizationId, id])
  @@unique([organizationId, formId, versionNumber])
  @@index([organizationId, formId, status])
  @@index([organizationId, status])
  @@index([posterMediaId])
  @@map("form_versions")
}

// ─── Ordered wizard steps within a FormVersion ───────────────────────────────
//
// Fields may optionally belong to a step via FormField.formStepId.
// Existing forms keep formStepId null and continue to render as a flat list.

model FormStep {
  id             String   @id @default(cuid())
  organizationId String
  formVersionId  String
  stepKey        String
  sortOrder      Int
  title          String
  description    String?
  settings       Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  formVersion  FormVersion  @relation(fields: [organizationId, formVersionId], references: [organizationId, id], onDelete: Cascade)
  fields       FormField[]

  @@unique([organizationId, id])
  @@unique([organizationId, formVersionId, stepKey])
  @@unique([organizationId, formVersionId, sortOrder])
  @@index([organizationId, formVersionId, sortOrder])
  @@map("form_steps")
}

model FormField {
  id                   String            @id @default(cuid())
  organizationId       String
  formVersionId        String
  formStepId           String?
  fieldKey             String
  sortOrder            Int
  type                 FormFieldType
  semantic             FormFieldSemantic @default(NONE)
  label                String
  helpText             String?
  placeholder          String?
  required             Boolean           @default(false)
  config               Json              @default("{}")
  visibilityConditions Json?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  formVersion  FormVersion  @relation(fields: [organizationId, formVersionId], references: [organizationId, id], onDelete: Cascade)
  formStep     FormStep?    @relation(fields: [organizationId, formStepId], references: [organizationId, id], onDelete: Restrict)
  answers      FormAnswer[]

  @@unique([organizationId, formVersionId, fieldKey])
  @@unique([organizationId, formVersionId, sortOrder])
  @@unique([organizationId, id])
  @@index([organizationId, formVersionId, sortOrder])
  @@index([organizationId, formStepId, sortOrder])
  @@map("form_fields")
}

// ─── Submissions (pinned to exact version) ───────────────────────────────────

model FormSubmission {
  id                      String               @id @default(cuid())
  organizationId          String
  branchId                String
  formId                  String
  formVersionId           String
  status                  FormSubmissionStatus @default(RECEIVED)
  submittedAt             DateTime             @default(now())
  mobile                  String?
  mobileRaw               String?
  normalizedMobile        String?
  email                   String?
  leadId                  String?
  matchedCrmLeadId        String?
  isDuplicateInForm       Boolean              @default(false)
  existsInCrm             Boolean              @default(false)
  duplicateOfSubmissionId String?
  ipAddress               String?
  userAgent               String?
  metadata                Json?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  deletedAt               DateTime?

  organization          Organization         @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch                Branch               @relation(fields: [organizationId, branchId], references: [organizationId, id], onDelete: Restrict)
  form                  Form                 @relation(fields: [organizationId, formId], references: [organizationId, id], onDelete: Restrict)
  formVersion           FormVersion          @relation(fields: [organizationId, formVersionId], references: [organizationId, id], onDelete: Restrict)
  lead                  Lead?                @relation(fields: [organizationId, branchId, leadId], references: [organizationId, branchId, id], onDelete: Restrict)
  duplicateOfSubmission FormSubmission?      @relation("SubmissionDuplicates", fields: [duplicateOfSubmissionId], references: [id], onDelete: Restrict)
  duplicates            FormSubmission[]     @relation("SubmissionDuplicates")
  answers               FormAnswer[]
  tags                  FormSubmissionTag[]
  bookingReservations   BookingReservation[]

  @@unique([organizationId, branchId, id])
  @@unique([organizationId, id])
  @@index([organizationId, formId, submittedAt])
  @@index([organizationId, formVersionId, submittedAt])
  @@index([organizationId, formId, normalizedMobile])
  @@index([organizationId, normalizedMobile])
  @@index([organizationId, status])
  @@index([organizationId, existsInCrm])
  @@index([organizationId, isDuplicateInForm])
  @@index([organizationId, leadId])
  @@index([organizationId, deletedAt])
  @@map("form_submissions")
}

model FormAnswer {
  id             String    @id @default(cuid())
  organizationId String
  submissionId   String
  fieldId        String
  fieldKey       String
  valueText      String?
  valueLongText  String?
  valueNumber    Decimal?  @db.Decimal(18, 4)
  valueDate      DateTime? @db.Date
  valueJson      Json?
  createdAt      DateTime  @default(now())

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  submission   FormSubmission @relation(fields: [organizationId, submissionId], references: [organizationId, id], onDelete: Cascade)
  field        FormField      @relation(fields: [organizationId, fieldId], references: [organizationId, id], onDelete: Restrict)

  @@unique([organizationId, submissionId, fieldId])
  @@index([organizationId, fieldId])
  @@index([organizationId, fieldKey])
  @@index([organizationId, submissionId])
  @@map("form_answers")
}

// ─── Normalized tags ─────────────────────────────────────────────────────────

model Tag {
  id             String    @id @default(cuid())
  organizationId String
  slug           String
  name           String
  color          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  forms        FormTag[]
  submissions  FormSubmissionTag[]

  @@unique([organizationId, slug])
  @@unique([organizationId, id])
  @@index([organizationId, deletedAt])
  @@map("tags")
}

model FormTag {
  id             String   @id @default(cuid())
  organizationId String
  formId         String
  tagId          String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  form         Form         @relation(fields: [organizationId, formId], references: [organizationId, id], onDelete: Cascade)
  tag          Tag          @relation(fields: [organizationId, tagId], references: [organizationId, id], onDelete: Cascade)

  @@unique([organizationId, formId, tagId])
  @@index([organizationId, tagId])
  @@map("form_tags")
}

model FormSubmissionTag {
  id             String   @id @default(cuid())
  organizationId String
  submissionId   String
  tagId          String
  createdAt      DateTime @default(now())

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  submission   FormSubmission @relation(fields: [organizationId, submissionId], references: [organizationId, id], onDelete: Cascade)
  tag          Tag            @relation(fields: [organizationId, tagId], references: [organizationId, id], onDelete: Cascade)

  @@unique([organizationId, submissionId, tagId])
  @@index([organizationId, tagId])
  @@map("form_submission_tags")
}

// ─── Automation-ready foundation (no execution in 3.4A) ────────────────────────

model AutomationRule {
  id               String          @id @default(cuid())
  organizationId   String
  formId           String?
  bookingServiceId String?
  pipelineId       String?
  stageId          String?
  name             String
  trigger          DomainEventType
  isEnabled        Boolean         @default(false)
  /// Safe condition JSON — see lib/crm/automation-contract.ts
  conditions       Json            @default("{}")
  /// Safe action list JSON — see lib/crm/automation-contract.ts
  actionConfig     Json            @default("{}")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  deletedAt        DateTime?

  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  form           Form?                 @relation(fields: [organizationId, formId], references: [organizationId, id], onDelete: Cascade)
  bookingService BookingService?       @relation(fields: [organizationId, bookingServiceId], references: [organizationId, id], onDelete: Restrict)
  pipeline       CrmPipeline?          @relation(fields: [organizationId, pipelineId], references: [organizationId, id], onDelete: Restrict)
  stage          CrmPipelineStage?     @relation(fields: [organizationId, stageId], references: [organizationId, id], onDelete: Restrict)
  executions     AutomationExecution[]
  crmTasks       CrmTask[]

  @@unique([organizationId, id])
  @@index([organizationId, trigger, isEnabled])
  @@index([organizationId, formId])
  @@index([organizationId, bookingServiceId])
  @@index([organizationId, deletedAt])
  @@map("automation_rules")
}

model DomainEventOutbox {
  id             String            @id @default(cuid())
  organizationId String
  branchId       String?
  eventType      DomainEventType
  aggregateType  String
  aggregateId    String
  payload        Json
  status         DomainEventStatus @default(PENDING)
  attemptCount   Int               @default(0)
  availableAt    DateTime          @default(now())
  processedAt    DateTime?
  lastError      String?
  createdAt      DateTime          @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch       Branch?      @relation(fields: [organizationId, branchId], references: [organizationId, id], onDelete: Restrict)

  @@index([status, availableAt])
  @@index([organizationId, eventType, createdAt])
  @@index([organizationId, aggregateType, aggregateId])
  @@map("domain_event_outbox")
}

// ─── Analytics (not stored in Form.settings) ─────────────────────────────────
// FormAnalyticsEvent: raw events for funnels and conversion.
// FormAnalyticsDaily: materialized daily rollups using non-null dimension + dimensionKey.

model FormAnalyticsEvent {
  id             String                 @id @default(cuid())
  organizationId String
  formId         String
  formVersionId  String?
  branchId       String?
  eventType      FormAnalyticsEventType
  sessionId      String?
  occurredAt     DateTime               @default(now())
  metadata       Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  form         Form         @relation(fields: [organizationId, formId], references: [organizationId, id], onDelete: Cascade)
  formVersion  FormVersion? @relation(fields: [organizationId, formVersionId], references: [organizationId, id], onDelete: Restrict)
  branch       Branch?      @relation(fields: [organizationId, branchId], references: [organizationId, id], onDelete: Restrict)

  @@index([organizationId, formId, occurredAt])
  @@index([organizationId, formVersionId, occurredAt])
  @@index([organizationId, branchId, occurredAt])
  @@index([organizationId, eventType, occurredAt])
  @@map("form_analytics_events")
}

model FormAnalyticsDaily {
  id                 String                      @id @default(cuid())
  organizationId     String
  formId             String
  dimension          FormAnalyticsDailyDimension
  dimensionKey       String
  date               DateTime                    @db.Date
  viewCount          Int                         @default(0)
  startCount         Int                         @default(0)
  submitSuccessCount Int                         @default(0)
  submitFailureCount Int                         @default(0)
  updatedAt          DateTime                    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  form         Form         @relation(fields: [organizationId, formId], references: [organizationId, id], onDelete: Cascade)

  @@unique([organizationId, formId, dimension, dimensionKey, date])
  @@index([organizationId, date])
  @@index([organizationId, formId, date])
  @@index([organizationId, formId, dimension, date])
  @@map("form_analytics_daily")
}

// ─── Smart Booking Engine models (StarOS v0.5) ──────────────────────────────
// Standalone transactional domain. Optionally linked to Form / FormSubmission.
// Store all slot/reservation instants in UTC. Convert Asia/Tehran ↔ UTC at boundaries.
// Never store Jalali strings as authoritative timestamps.

model BookingService {
  id                     String    @id @default(cuid())
  organizationId         String
  branchId               String?
  formId                 String?
  slug                   String
  title                  String
  description            String?
  durationMinutes        Int
  bufferBeforeMinutes    Int       @default(0)
  bufferAfterMinutes     Int       @default(0)
  minimumLeadTimeMinutes Int       @default(60)
  maximumAdvanceDays     Int       @default(30)
  meetingTypes           Json      @default("[\"IN_PERSON\"]")
  isActive               Boolean   @default(true)
  settings               Json      @default("{}")
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  deletedAt              DateTime?

  organization      Organization                   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch            Branch?                        @relation(fields: [organizationId, branchId], references: [organizationId, id], onDelete: Restrict)
  form              Form?                          @relation(fields: [organizationId, formId], references: [organizationId, id], onDelete: Restrict)
  advisorLinks      BookingAdvisorService[]
  availabilityRules BookingAvailabilityRule[]
  exceptions        BookingAvailabilityException[]
  slots             BookingSlot[]
  sitePlacements    SitePlacement[]
  automationRules   AutomationRule[]

  @@unique([organizationId, slug])
  @@unique([organizationId, id])
  @@index([organizationId, isActive])
  @@index([organizationId, deletedAt])
  @@index([organizationId, formId])
  @@map("booking_services")
}

model BookingAdvisor {
  id             String    @id @default(cuid())
  organizationId String
  branchId       String?
  userId         String?
  displayName    String
  description    String?
  colorKey       String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization      Organization                   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch            Branch?                        @relation(fields: [organizationId, branchId], references: [organizationId, id], onDelete: Restrict)
  user              User?                          @relation(fields: [userId], references: [id], onDelete: Restrict)
  serviceLinks      BookingAdvisorService[]
  availabilityRules BookingAvailabilityRule[]
  exceptions        BookingAvailabilityException[]
  slots             BookingSlot[]

  @@unique([organizationId, id])
  @@index([organizationId, isActive])
  @@index([organizationId, deletedAt])
  @@index([organizationId, userId])
  @@map("booking_advisors")
}

model BookingAdvisorService {
  id             String   @id @default(cuid())
  organizationId String
  advisorId      String
  serviceId      String
  createdAt      DateTime @default(now())

  advisor BookingAdvisor @relation(fields: [organizationId, advisorId], references: [organizationId, id], onDelete: Cascade)
  service BookingService @relation(fields: [organizationId, serviceId], references: [organizationId, id], onDelete: Cascade)

  @@unique([organizationId, advisorId, serviceId])
  @@index([organizationId, serviceId])
  @@map("booking_advisor_services")
}

/// Weekday: 0 = Saturday … 6 = Friday (Persian week, Saturday-first).
model BookingAvailabilityRule {
  id             String    @id @default(cuid())
  organizationId String
  advisorId      String
  serviceId      String?
  weekday        Int
  startLocalTime String
  endLocalTime   String
  slotCapacity   Int       @default(1)
  validFrom      DateTime?
  validUntil     DateTime?
  timezone       String    @default("Asia/Tehran")
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  advisor BookingAdvisor  @relation(fields: [organizationId, advisorId], references: [organizationId, id], onDelete: Cascade)
  service BookingService? @relation(fields: [organizationId, serviceId], references: [organizationId, id], onDelete: Cascade)

  @@index([organizationId, advisorId, weekday, isActive])
  @@index([organizationId, serviceId])
  @@map("booking_availability_rules")
}

model BookingAvailabilityException {
  id             String   @id @default(cuid())
  organizationId String
  advisorId      String
  serviceId      String?
  /// Local calendar day in Asia/Tehran (date-only UTC noon sentinel avoided — store as Date @db.Date).
  localDate      DateTime @db.Date
  isClosed       Boolean  @default(true)
  startLocalTime String?
  endLocalTime   String?
  slotCapacity   Int?
  reason         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  advisor BookingAdvisor  @relation(fields: [organizationId, advisorId], references: [organizationId, id], onDelete: Cascade)
  service BookingService? @relation(fields: [organizationId, serviceId], references: [organizationId, id], onDelete: Cascade)

  @@index([organizationId, advisorId, localDate])
  @@index([organizationId, serviceId, localDate])
  @@map("booking_availability_exceptions")
}

model BookingSlot {
  id             String            @id @default(cuid())
  organizationId String
  serviceId      String
  advisorId      String
  branchId       String?
  startsAt       DateTime
  endsAt         DateTime
  capacity       Int
  bookedCount    Int               @default(0)
  waitingCount   Int               @default(0)
  status         BookingSlotStatus @default(OPEN)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  service      BookingService       @relation(fields: [organizationId, serviceId], references: [organizationId, id], onDelete: Restrict)
  advisor      BookingAdvisor       @relation(fields: [organizationId, advisorId], references: [organizationId, id], onDelete: Restrict)
  branch       Branch?              @relation(fields: [organizationId, branchId], references: [organizationId, id], onDelete: Restrict)
  reservations BookingReservation[]

  @@unique([organizationId, serviceId, advisorId, startsAt])
  @@unique([organizationId, id])
  @@index([organizationId, serviceId, startsAt, status])
  @@index([organizationId, advisorId, startsAt, status])
  @@index([organizationId, branchId, startsAt])
  @@index([organizationId, status, startsAt])
  @@map("booking_slots")
}

model BookingReservation {
  id                   String             @id @default(cuid())
  organizationId       String
  slotId               String
  formSubmissionId     String?
  leadId               String?
  status               BookingStatus      @default(PENDING)
  meetingType          BookingMeetingType @default(IN_PERSON)
  firstName            String
  lastName             String
  normalizedMobile     String
  normalizedEmail      String?
  normalizedNationalId String?
  trackingCode         String
  cancelTokenHash      String?
  checkInTokenHash     String?
  rescheduledFromId    String?
  notes                String?
  checkedInAt          DateTime?
  riskHint             String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  deletedAt            DateTime?

  organization    Organization         @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  slot            BookingSlot          @relation(fields: [organizationId, slotId], references: [organizationId, id], onDelete: Restrict)
  formSubmission  FormSubmission?      @relation(fields: [organizationId, formSubmissionId], references: [organizationId, id], onDelete: Restrict)
  lead            Lead?                @relation(fields: [organizationId, leadId], references: [organizationId, id], onDelete: Restrict)
  rescheduledFrom BookingReservation?  @relation("BookingRescheduleChain", fields: [rescheduledFromId], references: [id], onDelete: Restrict)
  rescheduledTo   BookingReservation[] @relation("BookingRescheduleChain")
  checkIns        BookingCheckIn[]

  @@unique([organizationId, trackingCode])
  @@unique([organizationId, id])
  @@index([organizationId, slotId, status])
  @@index([organizationId, normalizedMobile, status])
  @@index([organizationId, normalizedNationalId, status])
  @@index([organizationId, status, createdAt])
  @@index([organizationId, formSubmissionId])
  @@index([organizationId, leadId])
  @@index([organizationId, deletedAt])
  @@map("booking_reservations")
}

model BookingCheckIn {
  id                String               @id @default(cuid())
  organizationId    String
  reservationId     String
  checkedInByUserId String
  method            BookingCheckInMethod @default(QR)
  createdAt         DateTime             @default(now())

  reservation     BookingReservation @relation(fields: [organizationId, reservationId], references: [organizationId, id], onDelete: Restrict)
  checkedInByUser User               @relation(fields: [checkedInByUserId], references: [id], onDelete: Restrict)

  @@unique([organizationId, reservationId])
  @@index([organizationId, createdAt])
  @@map("booking_check_ins")
}

// ─── Site placements (StarOS v0.5.2B) ────────────────────────────────────────
// Admin-managed embeds for fixed public pages. Not a generic page builder.
// Resolution priority: enabled DB placement → env slug fallback → none.
// A disabled DB row suppresses env fallback (explicit admin disable).

enum SitePlacementKey {
  PRE_REGISTRATION_FORM
  CONSULTATION_FORM
  CONSULTATION_BOOKING
}

enum SitePlacementContentType {
  FORM
  BOOKING
  NONE
}

enum SitePlacementDisplayMode {
  FULL
  EMBEDDED
  COMPACT
  CARD
}

// ─── Communication / SMS / OTP (StarOS v0.6A) ────────────────────────────────
// Provider-neutral queue + hashed OTP challenges. Never store plaintext OTP.
// Secrets (API keys) live only in environment variables.

enum SmsMessageStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  DEAD_LETTER
  CANCELLED
}

enum SmsTemplatePurpose {
  BOOKING_CONFIRMATION
  FORM_CONFIRMATION
  OTP
  CUSTOM
}

enum OtpPurpose {
  LOGIN
  STAFF_LOGIN
  VERIFY_MOBILE
  BOOKING
  FORM
  GENERIC
}

enum OtpChallengeStatus {
  PENDING
  VERIFIED
  CONSUMED
  EXPIRED
  LOCKED
}

enum CrmCallOutcome {
  ANSWERED
  NO_ANSWER
  BUSY
  OFF
  WRONG_NUMBER
  FOLLOW_UP_REQUIRED
  CONSULTATION_BOOKED
  NOT_INTERESTED
  REGISTERED
  OTHER
}

model SitePlacement {
  id               String                   @id @default(cuid())
  organizationId   String
  placementKey     SitePlacementKey
  contentType      SitePlacementContentType @default(NONE)
  formId           String?
  bookingServiceId String?
  displayMode      SitePlacementDisplayMode @default(EMBEDDED)
  showPoster       Boolean                  @default(false)
  isEnabled        Boolean                  @default(true)
  heading          String?
  description      String?
  ctaLabel         String?
  sortOrder        Int                      @default(0)
  settings         Json                     @default("{}")
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  deletedAt        DateTime?

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  form           Form?           @relation(fields: [organizationId, formId], references: [organizationId, id], onDelete: Restrict)
  bookingService BookingService? @relation(fields: [organizationId, bookingServiceId], references: [organizationId, id], onDelete: Restrict)

  @@unique([organizationId, placementKey])
  @@unique([organizationId, id])
  @@index([organizationId, deletedAt])
  @@index([organizationId, isEnabled])
  @@index([organizationId, formId])
  @@index([organizationId, bookingServiceId])
  @@map("site_placements")
}

// ─── SMS templates, outbound queue, OTP challenges (StarOS v0.6A) ───────────

model SmsTemplate {
  id             String             @id @default(cuid())
  organizationId String
  code           String
  name           String
  purpose        SmsTemplatePurpose @default(CUSTOM)
  body           String
  /// Declared variable names for rendering (e.g. ["trackingCode","date","time"]).
  variables      Json               @default("[]")
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  messages     SmsMessage[]

  @@unique([organizationId, code])
  @@unique([organizationId, id])
  @@index([organizationId, purpose, isActive])
  @@index([organizationId, deletedAt])
  @@map("sms_templates")
}

model SmsMessage {
  id                String           @id @default(cuid())
  organizationId    String
  templateId        String?
  /// Normalized Iranian mobile (09xxxxxxxxx).
  toMobile          String
  body              String
  status            SmsMessageStatus @default(PENDING)
  provider          String           @default("null")
  providerMessageId String?
  /// Semantic purpose key (e.g. booking_confirmation, form_confirmation, otp).
  purpose           String
  relatedType       String?
  relatedId         String?
  attemptCount      Int              @default(0)
  maxAttempts       Int              @default(5)
  availableAt       DateTime         @default(now())
  sentAt            DateTime?
  lastError         String?
  /// Unique per organization — protects against duplicate enqueue.
  idempotencyKey    String
  metadata          Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  template     SmsTemplate? @relation(fields: [organizationId, templateId], references: [organizationId, id], onDelete: Restrict)

  @@unique([organizationId, idempotencyKey])
  @@unique([organizationId, id])
  @@index([status, availableAt])
  @@index([organizationId, status, createdAt])
  @@index([organizationId, purpose, createdAt])
  @@index([organizationId, relatedType, relatedId])
  @@index([organizationId, toMobile, createdAt])
  @@map("sms_messages")
}

model OtpChallenge {
  id                String             @id @default(cuid())
  organizationId    String
  normalizedMobile  String
  purpose           OtpPurpose         @default(GENERIC)
  /// sha256$saltHex$hashHex — never plaintext.
  codeHash          String
  status            OtpChallengeStatus @default(PENDING)
  expiresAt         DateTime
  attemptCount      Int                @default(0)
  maxAttempts       Int                @default(5)
  consumedAt        DateTime?
  lastSentAt        DateTime?
  resendAvailableAt DateTime?
  idempotencyKey    String?
  metadata          Json?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@unique([organizationId, id])
  @@index([organizationId, normalizedMobile, purpose, status])
  @@index([organizationId, status, expiresAt])
  @@index([organizationId, idempotencyKey])
  @@map("otp_challenges")
}

// ─── CRM Automation Engine (StarOS v0.7) ─────────────────────────────────────
// LeadStatus remains for legacy compatibility. CrmPipelineStage is the operational
// source of truth when stageId is set. Mapping: CrmStageType → LeadStatus in lib/crm.

model CrmPipeline {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  code           String
  isDefault      Boolean   @default(false)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  stages          CrmPipelineStage[]
  leads           Lead[]
  automationRules AutomationRule[]

  @@unique([organizationId, code])
  @@unique([organizationId, id])
  @@index([organizationId, isDefault, isActive])
  @@index([organizationId, deletedAt])
  @@map("crm_pipelines")
}

model CrmPipelineStage {
  id             String       @id @default(cuid())
  organizationId String
  pipelineId     String
  name           String
  code           String
  colorKey       String?
  position       Int
  stageType      CrmStageType @default(NEW)
  isTerminal     Boolean      @default(false)
  isWon          Boolean      @default(false)
  isLost         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  pipeline        CrmPipeline      @relation(fields: [organizationId, pipelineId], references: [organizationId, id], onDelete: Restrict)
  leads           Lead[]
  automationRules AutomationRule[]

  @@unique([organizationId, pipelineId, code])
  @@unique([organizationId, pipelineId, position])
  @@unique([organizationId, id])
  @@index([organizationId, pipelineId, position])
  @@index([organizationId, deletedAt])
  @@map("crm_pipeline_stages")
}

model CrmTask {
  id               String          @id @default(cuid())
  organizationId   String
  leadId           String
  assignedToUserId String?
  title            String
  description      String?
  taskType         CrmTaskType     @default(FOLLOW_UP)
  priority         CrmTaskPriority @default(NORMAL)
  status           CrmTaskStatus   @default(OPEN)
  dueAt            DateTime?
  completedAt      DateTime?
  cancelledAt      DateTime?
  createdByUserId  String?
  automationRuleId String?
  idempotencyKey   String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  deletedAt        DateTime?

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  lead           Lead            @relation(fields: [organizationId, leadId], references: [organizationId, id], onDelete: Restrict)
  assignedTo     User?           @relation("CrmTaskAssignee", fields: [assignedToUserId], references: [id], onDelete: Restrict)
  createdBy      User?           @relation("CrmTaskCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  automationRule AutomationRule? @relation(fields: [organizationId, automationRuleId], references: [organizationId, id], onDelete: Restrict)
  activities     CrmActivity[]
  callLogs       CrmCallLog[]

  @@unique([organizationId, idempotencyKey])
  @@unique([organizationId, id])
  @@index([organizationId, leadId, status])
  @@index([organizationId, assignedToUserId, status])
  @@index([organizationId, dueAt, status])
  @@index([organizationId, deletedAt])
  @@map("crm_tasks")
}

model CrmActivity {
  id                          String          @id @default(cuid())
  organizationId              String
  leadId                      String
  activityType                CrmActivityType
  title                       String
  summary                     String?
  actorUserId                 String?
  relatedTaskId               String?
  relatedFormSubmissionId     String?
  relatedBookingReservationId String?
  metadata                    Json?
  occurredAt                  DateTime        @default(now())
  createdAt                   DateTime        @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  lead         Lead         @relation(fields: [organizationId, leadId], references: [organizationId, id], onDelete: Restrict)
  actor        User?        @relation("CrmActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  relatedTask  CrmTask?     @relation(fields: [organizationId, relatedTaskId], references: [organizationId, id], onDelete: Restrict)

  @@index([organizationId, leadId, occurredAt])
  @@index([organizationId, activityType, occurredAt])
  @@index([organizationId, relatedTaskId])
  @@map("crm_activities")
}

model CrmCallLog {
  id              String         @id @default(cuid())
  organizationId  String
  leadId          String
  membershipId    String
  outcome         CrmCallOutcome
  note            String?
  durationSeconds Int?
  calledAt        DateTime       @default(now())
  nextFollowUpAt  DateTime?
  createdTaskId   String?
  idempotencyKey  String
  createdAt       DateTime       @default(now())

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  lead         Lead                   @relation(fields: [organizationId, leadId], references: [organizationId, id], onDelete: Restrict)
  membership   OrganizationMembership @relation(fields: [organizationId, membershipId], references: [organizationId, id], onDelete: Restrict)
  createdTask  CrmTask?               @relation(fields: [organizationId, createdTaskId], references: [organizationId, id], onDelete: Restrict)

  @@unique([organizationId, idempotencyKey])
  @@unique([organizationId, id])
  @@index([organizationId, membershipId, calledAt])
  @@index([organizationId, leadId, calledAt])
  @@index([organizationId, outcome, calledAt])
  @@map("crm_call_logs")
}

model AutomationExecution {
  id               String                    @id @default(cuid())
  organizationId   String
  automationRuleId String
  domainEventId    String
  status           AutomationExecutionStatus @default(PENDING)
  attempts         Int                       @default(0)
  startedAt        DateTime?
  completedAt      DateTime?
  errorCode        String?
  lastError        String?
  idempotencyKey   String
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  automationRule AutomationRule @relation(fields: [organizationId, automationRuleId], references: [organizationId, id], onDelete: Restrict)

  @@unique([organizationId, automationRuleId, domainEventId])
  @@unique([organizationId, idempotencyKey])
  @@unique([organizationId, id])
  @@index([organizationId, status, createdAt])
  @@index([organizationId, domainEventId])
  @@map("automation_executions")
}

// ─── Institute website team CMS (not school-specific; not staff login accounts) ─

model TeamDepartment {
