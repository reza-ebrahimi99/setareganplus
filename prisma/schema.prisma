  organizationId String
  name           String
  slug           String
  icon           String?
  color          String?
  displayOrder   Int       @default(0)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  archivedAt     DateTime?
  deletedAt      DateTime?

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  achievements Achievement[]

  @@unique([organizationId, slug])
  @@unique([organizationId, id])
  @@index([organizationId, displayOrder])
  @@index([organizationId, isActive, deletedAt])
  @@map("achievement_categories")
}

model Achievement {
  id                 String    @id @default(cuid())
  organizationId     String
  studentId          String
  categoryId         String
  title              String
  slug               String
  shortDescription   String    @default("")
  description        String    @default("")
  achievementDate    DateTime?
  schoolYear         String?
  issuer             String?
  level              String?
  place              String?
  score              String?
  certificateMediaId String?
  coverMediaId       String?
  isFeatured         Boolean   @default(false)
  featuredPriority   Int       @default(0)
  displayOrder       Int       @default(0)
  seoTitle           String?
  seoDescription     String?
  isPublished        Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  archivedAt         DateTime?
  deletedAt          DateTime?

  organization     Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  student          Student             @relation(fields: [organizationId, studentId], references: [organizationId, id], onDelete: Restrict)
  category         AchievementCategory @relation(fields: [organizationId, categoryId], references: [organizationId, id], onDelete: Restrict)
  certificateMedia MediaAsset?         @relation("AchievementCertificate", fields: [certificateMediaId], references: [id], onDelete: SetNull)
  coverMedia       MediaAsset?         @relation("AchievementCover", fields: [coverMediaId], references: [id], onDelete: SetNull)

  @@unique([organizationId, slug])
  @@unique([organizationId, id])
  @@index([organizationId, studentId, achievementDate])
  @@index([organizationId, categoryId, displayOrder])
  @@index([organizationId, isFeatured, featuredPriority])
  @@index([organizationId, isPublished, deletedAt])
  @@index([organizationId, schoolYear])
  @@index([organizationId, isPublished, archivedAt, deletedAt, achievementDate])
  @@map("achievements")
}

// ─── Assessment Center (آزمون) — multi-provider exam results ─────────────────

enum AssessmentType {
  QALAMCHI
  SCHOOL_EXAM
  MIDTERM
  FINAL
  OLYMPIAD
  ENTRANCE
  OTHER
}

enum GuardianRelationshipType {
  FATHER
  MOTHER
  GUARDIAN
  OTHER
}

enum PortalAccountType {
  STUDENT
  GUARDIAN
}

/// Parent / legal guardian / authorized family member (portal identity, not public CMS).
model StudentGuardian {
  id               String                   @id @default(cuid())
  organizationId   String
  firstName        String
  lastName         String
  fullName         String
  nationalId       String?
  mobile           String
  normalizedMobile String
  relationshipType GuardianRelationshipType @default(GUARDIAN)
  isPrimary        Boolean                  @default(false)
  isActive         Boolean                  @default(true)
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  archivedAt       DateTime?
  deletedAt        DateTime?

  organization Organization              @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  relations    StudentGuardianRelation[]
  portalLinks  PortalAccountLink[]

  @@unique([organizationId, id])
  @@unique([organizationId, normalizedMobile])
  @@index([organizationId, fullName])
  @@index([organizationId, isActive, deletedAt])
  @@map("student_guardians")
}

model StudentGuardianRelation {
  id                      String                   @id @default(cuid())
  organizationId          String
  studentId               String
  guardianId              String
  relationshipType        GuardianRelationshipType @default(GUARDIAN)
  isPrimary               Boolean                  @default(false)
  canViewAcademicData     Boolean                  @default(true)
  canViewAchievements     Boolean                  @default(true)
  canViewCertificates     Boolean                  @default(true)
  canReceiveNotifications Boolean                  @default(true)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  deletedAt               DateTime?

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  student      Student         @relation(fields: [organizationId, studentId], references: [organizationId, id], onDelete: Restrict)
  guardian     StudentGuardian @relation(fields: [organizationId, guardianId], references: [organizationId, id], onDelete: Restrict)

  @@unique([organizationId, studentId, guardianId])
  @@unique([organizationId, id])
  @@index([organizationId, guardianId, deletedAt])
  @@index([organizationId, studentId, deletedAt])
  @@map("student_guardian_relations")
}

/// Links an authenticated User to exactly one Student OR one StudentGuardian (XOR enforced in SQL + services).
model PortalAccountLink {
  id             String            @id @default(cuid())
  organizationId String
  userId         String
  studentId      String?
  guardianId     String?
  accountType    PortalAccountType
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user         User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  /// Single-field FKs: Prisma optional composite FKs require all-or-nothing nulls.
  /// Organization match is enforced in portal/admin services.
  student      Student?         @relation(fields: [studentId], references: [id], onDelete: Restrict)
  guardian     StudentGuardian? @relation(fields: [guardianId], references: [id], onDelete: Restrict)

  @@unique([organizationId, id])
  @@index([organizationId, userId, deletedAt, isActive])
  @@index([userId, deletedAt, isActive])
  @@index([studentId])
  @@index([guardianId])
  @@map("portal_account_links")
}

model AssessmentProvider {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  slug           String
  displayOrder   Int       @default(0)
  color          String?
  icon           String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  archivedAt     DateTime?
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  assessments  Assessment[]

  @@unique([organizationId, slug])
  @@unique([organizationId, id])
  @@index([organizationId, displayOrder])
  @@index([organizationId, isActive, deletedAt])
  @@map("assessment_providers")
}

model Subject {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  slug           String
  shortName      String?
  displayOrder   Int       @default(0)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization   Organization              @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  subjectResults AssessmentSubjectResult[]

  @@unique([organizationId, slug])
  @@unique([organizationId, id])
  @@index([organizationId, displayOrder])
  @@index([organizationId, isActive, deletedAt])
  @@map("subjects")
}

model Assessment {
  id                     String         @id @default(cuid())
  organizationId         String
  providerId             String
  gradeId                String
  title                  String
  slug                   String
  assessmentType         AssessmentType @default(OTHER)
  assessmentDate         DateTime?
  schoolYear             String?
  participants           Int?
  maxScore               Float?
  description            String         @default("")
  isPublished            Boolean        @default(false)
  /// When true (and isPublished), featured results may appear on the public site.
  publishFeaturedResults Boolean        @default(false)
  /// Max results to auto-select as featured for this assessment (1–20).
  featuredResultsLimit   Int            @default(3)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  archivedAt             DateTime?
  deletedAt              DateTime?

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  provider     AssessmentProvider @relation(fields: [organizationId, providerId], references: [organizationId, id], onDelete: Restrict)
  grade        StudentGrade       @relation(fields: [organizationId, gradeId], references: [organizationId, id], onDelete: Restrict)
  results      AssessmentResult[]

  @@unique([organizationId, slug])
  @@unique([organizationId, id])
  @@index([organizationId, providerId, assessmentDate])
  @@index([organizationId, gradeId, assessmentDate])
  @@index([organizationId, assessmentType])
  @@index([organizationId, schoolYear])
  @@index([organizationId, isPublished, deletedAt])
  @@index([organizationId, isPublished, publishFeaturedResults, archivedAt, deletedAt])
  @@index([organizationId, isPublished, archivedAt, deletedAt, assessmentDate])
  @@map("assessments")
}

model AssessmentResult {
  id             String    @id @default(cuid())
  organizationId String
  studentId      String
  assessmentId   String
  score          Float?
  scaledScore    Float?
  rankSchool     Int?
  rankCity       Int?
  rankProvince   Int?
  rankCountry    Int?
  percentile     Float?
  growth         Float?
  averageClass   Float?
  averageGrade   Float?
  notes          String?
  isFeatured     Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization   Organization              @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  student        Student                   @relation(fields: [organizationId, studentId], references: [organizationId, id], onDelete: Restrict)
  assessment     Assessment                @relation(fields: [organizationId, assessmentId], references: [organizationId, id], onDelete: Restrict)
  subjectResults AssessmentSubjectResult[]

  @@unique([organizationId, studentId, assessmentId])
  @@unique([organizationId, id])
  @@index([organizationId, assessmentId, score])
  @@index([organizationId, studentId, createdAt])
  @@index([organizationId, isFeatured, deletedAt])
  @@map("assessment_results")
}

model AssessmentSubjectResult {
  id                 String @id @default(cuid())
  assessmentResultId String
  subjectId          String
  percentage         Float?
  correctAnswers     Int?
  wrongAnswers       Int?
  blankAnswers       Int?
  timeSpent          Int?

  assessmentResult AssessmentResult @relation(fields: [assessmentResultId], references: [id], onDelete: Cascade)
  subject          Subject          @relation(fields: [subjectId], references: [id], onDelete: Restrict)

  @@unique([assessmentResultId, subjectId])
  @@index([subjectId])
  @@map("assessment_subject_results")
}

// ─── Registration Engine v1 (reusable multi-product enrollment) ───────────────

enum RegistrationStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  COMPLETED
  CANCELLED
}

/// Product family — exam is first consumer; not hardcoded in the engine.
enum RegistrationProductType {
  EXAM
  CLASS
  CAMP
  WORKSHOP
  EVENT
  SCHOOL_ADMISSION
}

enum RegistrationParentRelationship {
  FATHER
  MOTHER
  GUARDIAN
  OTHER
}

/// Per-org Jalali-year sequence for REG-{year}-{seq}.
model RegistrationNumberCounter {
  id             String   @id @default(cuid())
  organizationId String
  jalaliYear     Int
  lastSequence   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@unique([organizationId, jalaliYear])
  @@index([organizationId])
  @@map("registration_number_counters")
}

/// Durable registration application (wizard → payment → CRM).
model Registration {
  id                 String                         @id @default(cuid())
  organizationId     String
  branchId           String
  registrationNumber String
  status             RegistrationStatus             @default(DRAFT)
  productType        RegistrationProductType
  /// Stable flow key, e.g. "qalamchi-exam". Drives catalog resolution.
  flowKey            String
  leadId             String?

  studentFirstName String
  studentLastName  String
  nationalCode     String
  birthDate        DateTime @db.Date
  gender           Gender
  gradeLabel       String
  majorLabel       String?
  schoolName       String
  province         String
  city             String

  parentName             String
  parentRelationship     RegistrationParentRelationship
  parentMobile           String
  parentMobileNormalized String
  parentSecondaryMobile  String?
  parentEmail            String?
  parentAddress          String?

  /// Selected product option keys + display titles (catalog-driven).
  productKey        String
  productTitle      String
  sessionKey        String?
  sessionTitle      String?
  packageKey        String?
  packageTitle      String?
  venueBranchKey    String?
  venueBranchTitle  String?
  discountCode      String?

  amountRials      Int
  discountRials    Int     @default(0)
  finalAmountRials Int
  currency         String  @default("IRR")

  /// Payment tracking placeholder (filled by PaymentService later).
  trackingCode    String?
  paymentProvider String?
  paymentRef      String?

  metadata  Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch       Branch       @relation(fields: [organizationId, branchId], references: [organizationId, id], onDelete: Restrict)
  lead         Lead?        @relation(fields: [organizationId, leadId], references: [organizationId, id], onDelete: Restrict)
  paymentIntents PaymentIntent[]

  @@unique([organizationId, registrationNumber])
  @@unique([organizationId, id])
  @@index([organizationId, status, createdAt])
  @@index([organizationId, flowKey, createdAt])
  @@index([organizationId, nationalCode])
  @@index([organizationId, parentMobileNormalized])
  @@index([organizationId, leadId])
  @@index([organizationId, deletedAt])
  @@map("registrations")
}

// ─── Payment Foundation (Sprint 4A) ───────────────────────────────────────────

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELLED
  EXPIRED
  REFUNDED
}

/// Payable unit for one Registration checkout (amounts snapshotted at create).
model PaymentIntent {
  id               String        @id @default(cuid())
  organizationId   String
  registrationId   String
  idempotencyKey   String
  status           PaymentStatus @default(PENDING)
  provider         String
  amountRials      Int
  discountRials    Int           @default(0)
  finalAmountRials Int
  currency         String        @default("IRR")
  description      String?
  trackingCode     String?
  receiptNumber    String?
  expiresAt        DateTime?
  paidAt           DateTime?
  failedAt         DateTime?
  cancelledAt      DateTime?
  metadata         Json?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  registration Registration    @relation(fields: [organizationId, registrationId], references: [organizationId, id], onDelete: Restrict)
  sessions     PaymentSession[]
  eventLogs    PaymentEventLog[]

  @@unique([organizationId, idempotencyKey])
  @@unique([organizationId, id])
  @@index([organizationId, registrationId, status])
  @@index([organizationId, status, createdAt])
  @@index([organizationId, trackingCode])
  @@index([organizationId, receiptNumber])
  @@map("payment_intents")
}

/// One provider checkout attempt under a PaymentIntent.
model PaymentSession {
  id               String        @id @default(cuid())
  organizationId   String
  paymentIntentId  String
  provider         String
  providerSessionId String
  status           PaymentStatus @default(PROCESSING)
  checkoutUrl      String?
  callbackToken    String
  rawRequestJson   Json?
  rawCallbackJson  Json?
  expiresAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  paymentIntent PaymentIntent @relation(fields: [organizationId, paymentIntentId], references: [organizationId, id], onDelete: Restrict)

  @@unique([organizationId, callbackToken])
  @@unique([organizationId, provider, providerSessionId])
  @@unique([organizationId, id])
  @@index([organizationId, paymentIntentId, createdAt])
  @@index([organizationId, status])
  @@map("payment_sessions")
}

/// Append-only payment transition log.
model PaymentEventLog {
  id              String         @id @default(cuid())
  organizationId  String
  paymentIntentId String
  fromStatus      PaymentStatus?
  toStatus        PaymentStatus
  event           String
  message         String?
  metadata        Json?
  createdAt       DateTime       @default(now())

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  paymentIntent PaymentIntent @relation(fields: [organizationId, paymentIntentId], references: [organizationId, id], onDelete: Restrict)

  @@index([organizationId, paymentIntentId, createdAt])
  @@map("payment_event_logs")
}
