// SetareganPlus — Multi-tenant data + identity foundation
//
// Tenancy rules:
// - Every tenant-owned row carries organizationId.
// - Branch-scoped rows also carry branchId.
// - Composite relations tie branchId to the parent organization.
// - Application queries must always filter by organizationId (never unscoped reads).
//
// Identity & access (Sprint 3.2A):
// - User accounts authenticate independently of tenant membership.
// - OrganizationMembership grants a SystemRole within one organization.
// - BranchMembership optionally limits a membership to specific branches.
// - No BranchMembership rows for an active membership = organization-wide branch access.
// - User.isPlatformAdmin is independent of tenant membership (never derived from it).
// - PLATFORM_ADMIN in SystemRole is reserved; platform operators use isPlatformAdmin.
//
// Authorization resolution (application layer, future):
//   authenticated User
//   → active OrganizationMembership (status ACTIVE, deletedAt null)
//   → SystemRole
//   → optional BranchMembership scope (empty = all branches in org)
//
// Defense in depth:
// - PostgreSQL Row Level Security (RLS) may be added in a future migration.
// - Do not create unscoped repository helpers; always pass organizationId.
//
// Partial unique indexes (future raw SQL migration):
// - normalizedMobile and email are @unique in Prisma; PostgreSQL allows multiple NULLs.
// - If stricter partial uniqueness is required later, add:
//   CREATE UNIQUE INDEX ... ON users (normalized_mobile) WHERE normalized_mobile IS NOT NULL;

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum LeadStatus {
  NEW
  CONTACTED
  NO_ANSWER
  CONSULTATION_SCHEDULED
  WAITING_FOR_DECISION
  WAITING_FOR_PAYMENT
  ENROLLED
  LOST
}

enum LeadActivityType {
  NOTE
  CALL
  STATUS_CHANGE
  ASSIGNMENT
  SYSTEM
}

enum ConsentType {
  PRE_REGISTRATION
  DATA_PROCESSING
  MARKETING_CONTACT
}

enum ServiceInterest {
  COURSES
  CLASSES
  EXAMS
  CONSULTATION
  UNDECIDED
}

enum Gender {
  MALE
  FEMALE
  UNSPECIFIED
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DISABLED
}

enum SystemRole {
  PLATFORM_ADMIN
  ORGANIZATION_OWNER
  ORGANIZATION_ADMIN
  BRANCH_MANAGER
  ADVISOR
  TEACHER
  FINANCE
  REGISTRATION_STAFF
  SUPPORT
  CONTENT_MANAGER
  STUDENT
  PARENT
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
  REVOKED
}

enum AuditAction {
  USER_CREATED
  USER_UPDATED
  MEMBERSHIP_CREATED
  MEMBERSHIP_UPDATED
  ROLE_CHANGED
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  LEAD_VIEWED
  LEAD_UPDATED
  DATA_EXPORTED
  SECURITY_EVENT
}

model Organization {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  legalName String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  branches    Branch[]
  leads       Lead[]
  memberships OrganizationMembership[]
  auditLogs   AuditLog[]

  @@map("organizations")
}

model Branch {
  id             String    @id @default(cuid())
  organizationId String
  name           String
  slug           String
  city           String?
  province       String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  // Restrict: hard-deleting an organization is blocked while branches exist.
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  leads             Lead[]
  activities        LeadActivity[]
  consents          ConsentRecord[]
  branchMemberships BranchMembership[]
  auditLogs         AuditLog[]

  @@unique([organizationId, slug])
  @@unique([organizationId, id])
  @@index([organizationId, isActive])
  @@index([organizationId, deletedAt])
  @@map("branches")
}

model User {
  id               String     @id @default(cuid())
  email            String?    @unique
  mobile           String?
  normalizedMobile String?    @unique
  passwordHash     String?
  firstName        String
  lastName         String
  status           UserStatus @default(INVITED)
  isPlatformAdmin  Boolean    @default(false)
  emailVerifiedAt  DateTime?
  mobileVerifiedAt DateTime?
  lastLoginAt      DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  deletedAt        DateTime?

  memberships OrganizationMembership[]
  auditLogs   AuditLog[]               @relation("AuditLogActor")

  @@index([status])
  @@index([deletedAt])
  @@index([isPlatformAdmin])
  @@map("users")
}

model OrganizationMembership {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  role           SystemRole
  status         MembershipStatus @default(INVITED)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?

  // Restrict: preserve membership history; soft-delete via deletedAt instead of hard delete.
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user              User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  branchMemberships BranchMembership[]

  // One membership row per user per organization. Reactivation after soft-delete must
  // UPDATE this row (clear deletedAt, adjust status) — not INSERT a duplicate.
  @@unique([organizationId, userId])
  @@unique([organizationId, id])
  @@index([organizationId, status])
  @@index([organizationId, role])
  @@index([organizationId, deletedAt])
  @@index([userId, status])
  @@map("organization_memberships")
}

model BranchMembership {
  id                       String    @id @default(cuid())
  organizationMembershipId String
  organizationId           String
  branchId                 String
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  deletedAt                DateTime?

  // Restrict: branch scope rows are historical access records, not cascade-deleted.
  // Composite FK: branchId must belong to the same organizationId.
  organizationMembership OrganizationMembership @relation(fields: [organizationId, organizationMembershipId], references: [organizationId, id], onDelete: Restrict)
  branch                 Branch                 @relation(fields: [organizationId, branchId], references: [organizationId, id], onDelete: Restrict)

  // One active scope row per branch per organization membership.
  @@unique([organizationMembershipId, branchId])
  @@index([organizationId, branchId])
  @@index([organizationId, organizationMembershipId])
  @@index([organizationId, deletedAt])
  @@map("branch_memberships")
}

model AuditLog {
  id             String      @id @default(cuid())
  organizationId String?
  branchId       String?
  actorUserId    String?
  action         AuditAction
  entityType     String
  entityId       String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime    @default(now())

  // Restrict: audit evidence must survive entity lifecycle; block hard deletes instead.
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  branch       Branch?       @relation(fields: [organizationId, branchId], references: [organizationId, id], onDelete: Restrict)
  // SetNull: retain audit rows if a user account is hard-deleted; actor becomes anonymous.
  actor        User?         @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([branchId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model Lead {
  id              String          @id @default(cuid())
  organizationId  String
  branchId        String
  status          LeadStatus      @default(NEW)
  firstName       String
  lastName        String
  fatherName      String?
  mobile          String
  mobileRaw       String
  school          String?
  gradeLevel      String?
  studyField      String?
  city            String?
  province        String?
  gender          Gender?
  birthDate       DateTime?       @db.Date
  nationalCode    String?
  serviceInterest ServiceInterest @default(UNDECIDED)
  description     String?
  source          String          @default("WEB_PRE_REGISTRATION")
  isDuplicate     Boolean         @default(false)
  duplicateOfId   String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  // Restrict: preserves historical leads when org/branch are soft-deleted (deletedAt).
  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  // Composite FK: branchId must belong to the same organizationId.
  branch       Branch          @relation(fields: [organizationId, branchId], references: [organizationId, id], onDelete: Restrict)
  // SetNull: removing the original lead does not delete duplicate records.
  duplicateOf  Lead?           @relation("LeadDuplicates", fields: [duplicateOfId], references: [id], onDelete: SetNull)
  duplicates   Lead[]          @relation("LeadDuplicates")
  activities   LeadActivity[]
  consents     ConsentRecord[]

  @@unique([organizationId, branchId, id])
  @@index([organizationId, branchId])
  @@index([organizationId, status])
  @@index([organizationId, mobile])
  @@index([organizationId, createdAt])
  @@index([organizationId, deletedAt])
  @@map("leads")
}

model LeadActivity {
  id             String           @id @default(cuid())
  organizationId String
  branchId       String
  leadId         String
  type           LeadActivityType
  content        String
  previousStatus LeadStatus?
  newStatus      LeadStatus?
  createdAt      DateTime         @default(now())

  // Cascade: activity rows are dependent history; only applies on hard delete.
  // Soft-deleted leads keep activities via deletedAt on Lead.
  lead   Lead   @relation(fields: [organizationId, branchId, leadId], references: [organizationId, branchId, id], onDelete: Cascade)
  branch Branch @relation(fields: [organizationId, branchId], references: [organizationId, id], onDelete: Restrict)

  @@index([organizationId, branchId])
  @@index([organizationId, leadId, createdAt])
  @@map("lead_activities")
}

model ConsentRecord {
  id             String      @id @default(cuid())
  organizationId String
  branchId       String
  leadId         String
  consentType    ConsentType
  consentText    String
  consentVersion String
  ipAddress      String?
  userAgent      String?
  grantedAt      DateTime    @default(now())

  // Cascade: consent evidence is tied to a lead record (hard delete only).
  lead   Lead   @relation(fields: [organizationId, branchId, leadId], references: [organizationId, branchId, id], onDelete: Cascade)
  branch Branch @relation(fields: [organizationId, branchId], references: [organizationId, id], onDelete: Restrict)

  @@index([organizationId, branchId])
  @@index([organizationId, leadId])
  @@map("consent_records")
}
